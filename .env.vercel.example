APP_ENV=production
APP_PORT=4000
DATABASE_PROVIDER=prisma
DATABASE_URL="postgresql://postgres.PROJECT_REF:PERCENT_ENCODED_PASSWORD@aws-REGION.pooler.supabase.com:6543/postgres?schema=public&sslmode=require"
JWT_ACCESS_SECRET=YOUR_LONG_RANDOM_ACCESS_SECRET
JWT_REFRESH_SECRET=YOUR_LONG_RANDOM_REFRESH_SECRET
ACCESS_TOKEN_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=30d
IDENTITY_BASE_URL=https://identity.trynexa-ai.com
CORS_ALLOWED_ORIGINS=https://trynexa-ai.com,https://www.trynexa-ai.com,https://identity.trynexa-ai.com
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_PUBLISHABLE_KEY=YOUR_SUPABASE_PUBLISHABLE_KEY
SUPABASE_SECRET_KEY=YOUR_SUPABASE_SECRET_KEY
SUPABASE_JWKS_URL=https://YOUR_PROJECT.supabase.co/auth/v1/.well-known/jwks.json
SUPABASE_OIDC_TOKEN_ENDPOINT=https://YOUR_PROJECT.supabase.co/auth/v1/oauth/token
SUPABASE_OIDC_AUTHORIZATION_ENDPOINT=https://YOUR_PROJECT.supabase.co/auth/v1/oauth/authorize
SUPABASE_OIDC_DISCOVERY_URL=https://YOUR_PROJECT.supabase.co/auth/v1/.well-known/openid-configuration
EMAIL_PROVIDER=resend
RESEND_API_KEY=YOUR_RESEND_API_KEY
EMAIL_PROVIDER_API_KEY=YOUR_RESEND_API_KEY
EMAIL_FROM=Nexa <noreply@trynexa-ai.com>
ADMIN_EMAIL_FROM=Nexa Admin <admin@trynexa-ai.com>
BILLING_PROVIDER=paypal
PAYPAL_CLIENT_ID=YOUR_PAYPAL_LIVE_CLIENT_ID
PAYPAL_CLIENT_SECRET=YOUR_PAYPAL_LIVE_CLIENT_SECRET
PAYPAL_ENVIRONMENT=live
PAYPAL_PLAN_IDS={}
ADMIN_DASHBOARD_ENABLED=false
ADMIN_DASHBOARD_HOST=127.0.0.1
ADMIN_DASHBOARD_PORT=3001
ADMIN_ALLOW_LAN=false
ADMIN_ALLOWED_IPS=127.0.0.1,::1
ADMIN_SESSION_EXPIRES_IN=2h
ADMIN_REQUIRE_HTTPS=true
ALLOW_OWNER_BOOTSTRAP=false
OWNER_BOOTSTRAP_TOKEN=
