APP_ENV=development
APP_PORT=4000
DATABASE_PROVIDER=prisma
# Supabase Postgres connection string. Prefer the transaction pooler on Vercel.
# Percent-encode special password characters; for example, @ becomes %40.
DATABASE_URL="postgresql://postgres.PROJECT_REF:PERCENT_ENCODED_PASSWORD@aws-REGION.pooler.supabase.com:6543/postgres?schema=public&sslmode=require"
JWT_ACCESS_SECRET="replace-with-a-long-random-access-secret"
JWT_REFRESH_SECRET="replace-with-a-long-random-refresh-secret"
ACCESS_TOKEN_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=30d
CORS_ALLOWED_ORIGINS="http://localhost:3000,http://127.0.0.1:3001,https://trynexa-ai.com,https://www.trynexa-ai.com,https://identity.trynexa-ai.com"
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_replace_me
SUPABASE_SECRET_KEY=sb_secret_replace_me
SUPABASE_JWKS_URL=https://your-project.supabase.co/auth/v1/.well-known/jwks.json
SUPABASE_OIDC_TOKEN_ENDPOINT=https://your-project.supabase.co/auth/v1/oauth/token
SUPABASE_OIDC_AUTHORIZATION_ENDPOINT=https://your-project.supabase.co/auth/v1/oauth/authorize
SUPABASE_OIDC_DISCOVERY_URL=https://your-project.supabase.co/auth/v1/.well-known/openid-configuration
EMAIL_PROVIDER=development
EMAIL_PROVIDER_API_KEY=
RESEND_API_KEY=
EMAIL_FROM="Nexa <noreply@nexa.ai>"
ADMIN_EMAIL_FROM="Nexa Admin <admin@admin.nexaidentity.com>"
IDENTITY_BASE_URL=http://127.0.0.1:4000
BILLING_PROVIDER_SECRET=
BILLING_PROVIDER=manual
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_ENVIRONMENT=sandbox
# Optional override. Nexa Identity ships with the current sandbox/live PayPal plan IDs.
PAYPAL_PLAN_IDS={}
ADMIN_DASHBOARD_ENABLED=false
ADMIN_DASHBOARD_HOST=127.0.0.1
ADMIN_DASHBOARD_PORT=3001
ADMIN_ALLOW_LAN=false
ADMIN_ALLOWED_IPS=127.0.0.1,::1
ADMIN_SESSION_EXPIRES_IN=2h
ADMIN_REQUIRE_HTTPS=false
ALLOW_OWNER_BOOTSTRAP=false
OWNER_BOOTSTRAP_TOKEN=
ADMIN_TEST_PASSWORD=Solution1@


