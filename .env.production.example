APP_ENV=production
APP_PORT=4000
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public&sslmode=require"
JWT_ACCESS_SECRET="replace-with-production-access-secret-64-plus-chars"
JWT_REFRESH_SECRET="replace-with-production-refresh-secret-64-plus-chars"
ACCESS_TOKEN_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=30d
CORS_ALLOWED_ORIGINS="https://trynexa-ai.com,https://www.trynexa-ai.com,https://identity.trynexa-ai.com"
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_replace_me
SUPABASE_SECRET_KEY=sb_secret_replace_me
SUPABASE_JWKS_URL=https://your-project.supabase.co/auth/v1/.well-known/jwks.json
SUPABASE_OIDC_TOKEN_ENDPOINT=https://your-project.supabase.co/auth/v1/oauth/token
SUPABASE_OIDC_AUTHORIZATION_ENDPOINT=https://your-project.supabase.co/auth/v1/oauth/authorize
SUPABASE_OIDC_DISCOVERY_URL=https://your-project.supabase.co/auth/v1/.well-known/openid-configuration
EMAIL_PROVIDER=resend
EMAIL_PROVIDER_API_KEY=
RESEND_API_KEY=
EMAIL_FROM="Nexa <noreply@nexaidentity.com>"
ADMIN_EMAIL_FROM="Nexa Admin <admin@admin.nexaidentity.com>"
IDENTITY_BASE_URL=https://identity.trynexa-ai.com
BILLING_PROVIDER=paypal
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_ENVIRONMENT=live
# Optional override. Nexa Identity ships with the current live PayPal plan IDs.
PAYPAL_PLAN_IDS={}
ADMIN_DASHBOARD_ENABLED=false
ADMIN_DASHBOARD_HOST=127.0.0.1
ADMIN_DASHBOARD_PORT=3001
ADMIN_ALLOW_LAN=false
ADMIN_ALLOWED_IPS=
ADMIN_SESSION_EXPIRES_IN=2h
ADMIN_REQUIRE_HTTPS=true
ALLOW_OWNER_BOOTSTRAP=false
OWNER_BOOTSTRAP_TOKEN=
